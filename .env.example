# Настройки PostgreSQL
DB_HOST=postgres_db
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Настройки для работы приложения
MOD_TO_B2B_KEY=MOD_TO_B2B_KEY
B2B_TO_B2C_KEY=B2B_TO_B2C_KEY
B2B_TO_MOD_KEY=B2B_TO_MOD_KEY
B2C_URL=http://localhost:8001/

# Настройки service-to-service B2C -> B2B
B2B_URL=http://localhost:8000
B2C_TO_B2B_KEY=B2C_TO_B2B_KEY
B2B_CATEGORIES_PATH=/api/v1/categories
